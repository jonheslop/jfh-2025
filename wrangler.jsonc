{
  "name": "jfh-2025",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-02-26",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "images": {
    "binding": "IMAGES"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  }
}
