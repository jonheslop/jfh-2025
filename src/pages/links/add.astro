---
export const prerender = false;

import { turso } from "../../utils/turso";
import Layout from "../../components/Layout.astro";

if (!import.meta.env.DEV) {
  return Astro.redirect("/links");
}

let message = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const title = data.get("title")?.toString() ?? "";
  const url = data.get("url")?.toString() ?? "";
  const comment = data.get("comment")?.toString() ?? "";
  const via = data.get("via")?.toString() ?? "";
  const date = data.get("date")?.toString() ?? new Date().toISOString().split("T")[0];

  const tags = data.get("tags")?.toString() ?? "";

  const typeSelect = data.get("type")?.toString() ?? "";
  const typeCustom = data.get("type-custom")?.toString() ?? "";
  const type = typeSelect === "__custom" ? typeCustom : typeSelect;

  if (title && url) {
    await turso().execute({
      sql: "INSERT INTO links (date, url, tags, type, title, comment, via) VALUES (?, ?, ?, ?, ?, ?, ?)",
      args: [date, url, tags, type, title, comment, via],
    });
    message = `Added "${title}"`;
  }
}

const db = turso();
const { rows: tagRows } = await db.execute("SELECT DISTINCT tags FROM links WHERE tags != ''");
const existingTags = [...new Set(tagRows.flatMap(r => (r.tags as string).split(",").map(t => t.trim())).filter(Boolean))].sort();

const { rows: typeRows } = await db.execute("SELECT DISTINCT type FROM links WHERE type != ''");
const existingTypes = [...new Set(typeRows.map(r => (r.type as string).trim()).filter(Boolean))].sort();
---

<Layout title="Add Link">
  <div class="sm:col-span-2 lg:col-span-5 lg:col-start-3">
    <h1 class="text-4xl font-semibold mb-8">Add Link</h1>
    {message && <p class="text-green-400 mb-4">{message}</p>}
    <form method="POST" class="flex flex-col gap-4 max-w-xl">
      <label class="flex flex-col gap-1">
        <span class="text-white/70">Title *</span>
        <input type="text" name="title" required class="bg-white/10 border border-white/20 rounded px-3 py-2 text-white" />
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-white/70">URL *</span>
        <input type="url" name="url" required class="bg-white/10 border border-white/20 rounded px-3 py-2 text-white" />
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-white/70">Date</span>
        <input type="date" name="date" value={new Date().toISOString().split("T")[0]} class="bg-white/10 border border-white/20 rounded px-3 py-2 text-white" />
      </label>
      <div class="flex flex-col gap-1">
        <span class="text-white/70">Tags</span>
        <div id="tag-chips" class="flex flex-wrap gap-2 my-2 empty:hidden"></div>
        <div class="relative">
          <input type="text" id="tag-input" autocomplete="off" placeholder="Type to search or add tags…" class="bg-white/10 border border-white/20 rounded px-3 py-2 text-white w-full" />
          <ul id="tag-suggestions" class="absolute left-0 right-0 top-full mt-1 bg-neutral-800 border border-white/20 rounded max-h-48 overflow-y-auto hidden z-10"></ul>
        </div>
        <input type="hidden" name="tags" id="tags-hidden" />
      </div>
      <fieldset class="flex flex-col gap-1" id="type-fieldset">
        <legend class="text-white/70">Type</legend>
        <select name="type" id="type-select" class="bg-white/10 border border-white/20 rounded px-3 py-2 text-white mt-1">
          <option value="">— Select —</option>
          {existingTypes.map(t => (
            <option value={t}>{t}</option>
          ))}
          <option value="__custom">Other…</option>
        </select>
        <input type="text" name="type-custom" id="type-custom" placeholder="Enter new type" class="bg-white/10 border border-white/20 rounded px-3 py-2 text-white mt-2 text-sm hidden" />
      </fieldset>
      <label class="flex flex-col gap-1">
        <span class="text-white/70">Comment (markdown)</span>
        <textarea name="comment" rows="4" class="bg-white/10 border border-white/20 rounded px-3 py-2 text-white"></textarea>
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-white/70">Via (markdown)</span>
        <input type="text" name="via" class="bg-white/10 border border-white/20 rounded px-3 py-2 text-white" />
      </label>
      <button type="submit" class="bg-white text-black font-semibold rounded px-4 py-2 mt-2 hover:bg-white/90 cursor-pointer self-start">
        Add Link
      </button>
    </form>
  </div>
    <div class="lg:col-span-5">
    <div class="mt-12">
      <h2 class="text-2xl font-semibold mb-4 text-white/70">Preview</h2>
      <ul>
        <li id="preview" class="border-t border-white/20 last:border-b group hover:bg-white/10 transition-colors py-6 lg:py-3">
          <a id="preview-link" href="#" class="block">
            <header class="flex gap-6">
              <h2 id="preview-title" class="text-lg font-bold leading-snug underline underline-offset-2 text-balance">Title</h2>
              <span id="preview-date" class="text-white/70 ml-auto shrink-0 text-lg leading-snug"></span>
            </header>
            <p class="text-sm leading-snug mt-1">
              <span id="preview-url" class="text-white/50"></span>
            </p>
            <div id="preview-comment" class="text-white text-base leading-snug mt-2 max-w-lg text-pretty mb-3 prose"></div>
          </a>
          <footer class="flex justify-between lg:items-center">
            <div id="preview-tags"></div>
            <div id="preview-via" class="text-white/70 flex gap-1 prose mb-2 shrink-0 hidden">
              <p>via</p> <div id="preview-via-content"></div>
            </div>
          </footer>
        </li>
      </ul>
    </div>
  </div>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/markdown-it@14/dist/markdown-it.min.js"></script>

<script is:inline define:vars={{ existingTags }}>
  const allTags = existingTags;
  const selectedTags = [];
  const chipsEl = document.getElementById("tag-chips");
  const inputEl = document.getElementById("tag-input");
  const suggestionsEl = document.getElementById("tag-suggestions");
  const hiddenEl = document.getElementById("tags-hidden");

  function syncHidden() {
    hiddenEl.value = selectedTags.join(", ");
    hiddenEl.dispatchEvent(new Event("input", { bubbles: true }));
  }

  function renderChips() {
    chipsEl.innerHTML = "";
    selectedTags.forEach((tag) => {
      const chip = document.createElement("span");
      chip.className =
        "inline-flex items-center gap-1 bg-white/20 text-white text-sm px-2 py-1 rounded-full";
      chip.textContent = tag;
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "text-white/60 hover:text-white ml-0.5 leading-none";
      btn.textContent = "×";
      btn.addEventListener("click", () => removeTag(tag));
      chip.appendChild(btn);
      chipsEl.appendChild(chip);
    });
    syncHidden();
  }

  function addTag(tag) {
    const t = tag.trim();
    if (!t || selectedTags.includes(t)) return;
    selectedTags.push(t);
    renderChips();
    inputEl.value = "";
    hideSuggestions();
  }

  function removeTag(tag) {
    const i = selectedTags.indexOf(tag);
    if (i > -1) selectedTags.splice(i, 1);
    renderChips();
  }

  function showSuggestions(filter) {
    const f = filter.toLowerCase();
    const matches = allTags.filter(
      (t) => t.toLowerCase().includes(f) && !selectedTags.includes(t)
    );
    if (matches.length === 0 && !f) {
      hideSuggestions();
      return;
    }
    suggestionsEl.innerHTML = "";
    matches.forEach((tag) => {
      const li = document.createElement("li");
      li.className = "px-3 py-2 cursor-pointer hover:bg-white/10 text-white text-sm";
      li.textContent = tag;
      li.addEventListener("mousedown", (e) => {
        e.preventDefault();
        addTag(tag);
      });
      suggestionsEl.appendChild(li);
    });
    // If the typed text doesn't exactly match an existing tag, offer to create it
    if (f && !allTags.some((t) => t.toLowerCase() === f)) {
      const li = document.createElement("li");
      li.className = "px-3 py-2 cursor-pointer hover:bg-white/10 text-white/50 text-sm italic";
      li.textContent = `Add "${filter.trim()}"`;
      li.addEventListener("mousedown", (e) => {
        e.preventDefault();
        addTag(filter.trim());
      });
      suggestionsEl.appendChild(li);
    }
    suggestionsEl.classList.remove("hidden");
  }

  function hideSuggestions() {
    suggestionsEl.classList.add("hidden");
  }

  inputEl.addEventListener("input", () => {
    const v = inputEl.value;
    if (v.length > 0) {
      showSuggestions(v);
    } else {
      hideSuggestions();
    }
  });

  inputEl.addEventListener("focus", () => {
    if (inputEl.value.length > 0) showSuggestions(inputEl.value);
  });

  inputEl.addEventListener("blur", () => {
    // Small delay to allow mousedown on suggestion
    setTimeout(hideSuggestions, 150);
  });

  inputEl.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      if (inputEl.value.trim()) addTag(inputEl.value);
    }
    if (e.key === "Backspace" && !inputEl.value && selectedTags.length) {
      removeTag(selectedTags[selectedTags.length - 1]);
    }
  });
</script>

<script is:inline>
  var md = window.markdownit();

  function prettifyUrl(url) {
    return url
      .replace(/https?:\/\//, "")
      .replace(/www\./, "")
      .replace(/\/$/, "")
      .replace(/\?.*/, "")
      .replace(/#.*/, "");
  }

  function updatePreview() {
    var form = document.querySelector("form");
    var title = form.querySelector('[name="title"]').value || "Title";
    var url = form.querySelector('[name="url"]').value || "";
    var date = form.querySelector('[name="date"]').value || "";
    var comment = form.querySelector('[name="comment"]').value || "";
    var via = form.querySelector('[name="via"]').value || "";
    var tags = document.getElementById("tags-hidden").value;

    document.getElementById("preview-title").textContent = title;
    document.getElementById("preview-link").href = url || "#";
    document.getElementById("preview-url").textContent = url ? prettifyUrl(url) : "";

    if (date) {
      var d = new Date(date + "T00:00:00");
      document.getElementById("preview-date").textContent = d.toLocaleDateString("en-GB", {
        year: "numeric", month: "long", day: "numeric"
      });
    } else {
      document.getElementById("preview-date").textContent = "";
    }

    document.getElementById("preview-comment").innerHTML = comment ? md.render(comment) : "";

    var viaEl = document.getElementById("preview-via");
    var viaContent = document.getElementById("preview-via-content");
    if (via) {
      viaEl.classList.remove("hidden");
      viaContent.innerHTML = md.render(via);
    } else {
      viaEl.classList.add("hidden");
    }

    var tagsContainer = document.getElementById("preview-tags");
    tagsContainer.innerHTML = "";
    if (tags) {
      tags.split(",").map(function(t) { return t.trim(); }).filter(Boolean).forEach(function(tag) {
        var a = document.createElement("a");
        a.href = "/links/tagged/" + encodeURIComponent(tag);
        a.className = "text-white/70 border px-2 pt-1 pb-1.5 rounded-full text-sm mr-2 mb-2 leading-none inline-flex items-center hover:bg-white hover:text-fenix-red border-white/70";
        a.textContent = tag;
        tagsContainer.appendChild(a);
      });
    }
  }

  // Listen to all form inputs
  document.querySelector("form").addEventListener("input", updatePreview);

  // Initial render
  updatePreview();
</script>

<script>
  const select = document.getElementById("type-select") as HTMLSelectElement;
  const custom = document.getElementById("type-custom") as HTMLInputElement;
  select.addEventListener("change", () => {
    custom.classList.toggle("hidden", select.value !== "__custom");
    if (select.value === "__custom") custom.focus();
  });
</script>
