---
import { getCollection } from "astro:content";
import { dateOptions } from "../utils/types";

interface Props {
  type: "posts" | "photos";
  recent?: boolean;
}

const { type, recent = false } = Astro.props;

const posts = (await getCollection(type))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(recent ? 1 : 0, recent ? 10 : undefined);
---

<ul>
  {
    posts.map((post) => (
      <li class="border-t border-white/20 last:border-b">
        <a
          class="flex flex-col py-2 gap-2 group hover:bg-white/10 transition-colors h-32 overflow-hidden"
          href={`/${type}/${post.id}/`}
        >
          <div class="flex justify-between items-start gap-x-4 flex-wrap">
            <h4 class="text-lg group-hover:underline flex-1 text-pretty">
              {post.data.title}
            </h4>
            <datetime class="text-lg text-white/70 ml-auto shrink-0" datetime={new Date(post.data.date).toISOString()}>
              {new Date(post.data.date).toLocaleDateString("en-GB", dateOptions)}
            </datetime>
          </div>
          <p class="text-white/70 leading-snug text-pretty max-w-xs">{post.data.description}</p>
        </a>
      </li>
    ))
  }
</ul>
{
  recent && (
    <a class="block text-white/70 hover mt-2" href={`/${type}/`}>
      See all {type} &raquo;
    </a>
  )
}
