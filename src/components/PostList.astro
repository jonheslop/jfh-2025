---
import { getCollection } from "astro:content";
import { dateOptions } from "../utils/types";

interface Props {
  type: "posts" | "photos";
  recent?: boolean;
}

const { type, recent = false } = Astro.props;

const posts = (await getCollection(type))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(recent ? 1 : 0, recent ? 10 : undefined);
---

<ul class="space-y-12">
  {
    posts.map((post) => (
      <li class="border-t border-white/20 last:border-b">
        <a
          class="flex justify-start items-start gap-x-4 py-2 group hover:bg-white/10 transition-colors"
          href={`/${type}/${post.id}/`}
        >
          <div>
            <h4 class="text-lg group-hover:underline flex-1 text-pretty">
              {post.data.title}
            </h4>
            <p class="text-white/70 leading-snug text-pretty">{post.data.description}</p>
          </div>
          <datetime class="text-lg text-white/70 ml-auto shrink-0" datetime={new Date(post.data.date).toISOString()}>
            {new Date(post.data.date).toLocaleDateString("en-GB", dateOptions)}
          </datetime>
        </a>
      </li>
    ))
  }
</ul>
{
  recent && (
    <a href={`/${type}/`} class="block text-white/70 hover mt-2">
      See all {type} &raquo;
    </a>
  )
}
